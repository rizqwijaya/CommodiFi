# Copy to apps/api/.env

# Sepolia RPC (Alchemy/Infura/public). Required for the indexer + live reads.
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/your-api-key

# REST API port.
PORT=4000

# Block to start indexing from. Set to the deployment block to avoid scanning all of history.
# 0 = let the indexer pick (currentBlock - INDEX_LOOKBACK).
START_BLOCK=0

# How many blocks back to look when START_BLOCK=0.
INDEX_LOOKBACK=50000

# SQLite file path (relative to apps/api).
DB_PATH=./data/commodifi.sqlite

# Indexer poll interval (ms). Higher = gentler on free RPC tiers (avoids 429s).
POLL_INTERVAL_MS=30000
