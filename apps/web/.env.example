# Copy to apps/web/.env

# Backend REST API base URL.
VITE_API_URL=http://localhost:4000

# Sepolia RPC for wagmi/viem (optional; falls back to a public endpoint).
VITE_SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/fdcf134fb04a46698944487300ca171d

# WalletConnect project id, used by RainbowKit. Get a free one at https://cloud.reown.com.
# Injected wallets (MetaMask) work with the built-in placeholder; WalletConnect-based
# wallets (mobile QR, etc.) require a real id.
VITE_WALLETCONNECT_PROJECT_ID=
