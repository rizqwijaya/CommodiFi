# Copy to apps/web/.env

# Backend REST API base URL.
VITE_API_URL=http://localhost:4000

# Sepolia RPC for wagmi/viem (optional; falls back to a public endpoint).
VITE_SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/your-api-key

# Optional WalletConnect project id (injected/MetaMask works without it).
VITE_WALLETCONNECT_PROJECT_ID=
