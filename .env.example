# Copy to .env and fill in. Never commit the real .env.

# Deployer private key (becomes owner of PriceOracle, CommodiFiVault, and all 4 tokens).
# Use a throwaway testnet key. Include the 0x prefix.
PRIVATE_KEY=0x...

# Sepolia RPC endpoint (Alchemy, Infura, public RPC, etc.)
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/your-api-key

# Etherscan API key for contract verification (--verify).
ETHERSCAN_API_KEY=your-etherscan-api-key
